@model AdminPanelNET.Models.Company

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Company</h4>
<hr />

<div class="row">
    <div class="col-12 col-md-8 col-lg-6">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label for="logoFile" class="control-label">Replace Logo</label>
                <input type="file"
                       id="logoFile"
                       name="logoFile"
                       class="form-control"
                       accept=".jpg,.jpeg,.png,.gif,.webp" />
                @Html.ValidationMessage("logoFile", "", new { @class = "d-block text-danger" })
                <small class="form-text text-muted">
                    Leave this empty if you want to keep the current logo.
                </small>

                @if (!string.IsNullOrWhiteSpace(Model.Logo))
                {
                    <div class="mt-2">
                        <p class="mb-1">Current logo:</p>
                        <img src="@Model.Logo" alt="@Model.Name logo" class="img-thumbnail" style="max-height: 120px;" />
                    </div>
                }
            </div>

            <div class="form-group mb-3">
                <label asp-for="Website" class="control-label"></label>
                <input asp-for="Website" class="form-control" />
                <span asp-validation-for="Website" class="text-danger"></span>
            </div>

            <div class="form-group d-flex gap-2 flex-wrap">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}