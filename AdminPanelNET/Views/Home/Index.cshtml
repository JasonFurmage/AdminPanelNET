@{
    ViewData["Title"] = "Dashboard";
}

<div class="text-center mb-4">
    <h1 class="display-5">Admin Panel</h1>
    <p class="lead">Manage companies and employees.</p>
</div>

<div class="row g-4">
    <div class="col-12 col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h4">Companies</h2>
                <p>View, create, edit, and delete company records.</p>
                <a asp-controller="Companies" asp-action="Index" class="btn btn-primary">Go to Companies</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h4">Employees</h2>
                <p>View, create, edit, and delete employee records.</p>
                <a asp-controller="Employees" asp-action="Index" class="btn btn-primary">Go to Employees</a>
            </div>
        </div>
    </div>
</div>